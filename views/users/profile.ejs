<% layout("/layouts/boilerplate") %>

<style>

    

    /* PROFILE HEADER */

    .profile-section{

        background:
        linear-gradient(
            135deg,
            #ff6b00,
            #ff3c00,
            #2b06ff
        );

        border-radius: 30px;

        padding: 3rem;

        color: white;

        position: relative;

        overflow: hidden;

        box-shadow:
        0 12px 30px rgba(0,0,0,0.15);
    }

    .profile-section::before{

        content: "";

        position: absolute;

        width: 250px;
        height: 250px;

        border-radius: 50%;

        background:
        rgba(255,255,255,0.08);

        top: -80px;
        right: -60px;
    }

    .profile-icon{

        width: 110px;
        height: 110px;

        border-radius: 50%;

        background: white;

        display: flex;

        justify-content: center;
        align-items: center;

        font-size: 4rem;

        color: #2b06ff;

        border: 5px solid rgba(255,255,255,0.4);

        box-shadow:
        0 8px 20px rgba(0,0,0,0.15);
    }

    .profile-details h2{

        font-weight: 700;

        margin-bottom: 0.8rem;
    }

    .profile-details p{

        margin-bottom: 0.5rem;

        font-size: 1rem;

        opacity: 0.95;
    }

    /* ARTICLE SECTION */

    .article-heading{

        color: #2b06ff;

        font-weight: 700;

        margin-bottom: 2rem;
    }

    .article-card{

        border: none;

        border-radius: 20px;

        overflow: hidden;

        background: white;

        box-shadow:
        0 8px 20px rgba(0,0,0,0.08);

        transition: 0.3s;
    }

    .article-card:hover{

        transform: translateY(-5px);
    }

    .article-card img{

        height: 18rem;

        object-fit: cover;
    }

    .article-card .card-body{

        padding: 1.2rem;
    }

    .status-badge{

        padding: 0.45rem 1rem;

        border-radius: 30px;

        font-size: 0.8rem;

        font-weight: 600;
    }

    .approved{

        background: #198754;

        color: white;
    }

    .pending{

        background: #ffc107;

        color: black;
    }

    .rejected{

        background: #dc3545;

        color: white;
    }

</style>

<div class="container py-5">

    <!-- PROFILE SECTION -->

    <div class="profile-section mb-5">

        <div class="row align-items-center">

            <div class="col-md-2 text-center">

                <div class="profile-icon mx-auto">

                    <i class="fa-solid fa-user"></i>

                </div>

            </div>

            <div class="col-md-10 profile-details">

                <h2>
                    <%= user.username %>
                </h2>

                <p>
                    <i class="fa-solid fa-envelope"></i>

                    <%= user.email %>
                </p>

                <p>
                    <i class="fa-solid fa-shield"></i>

                    <%= user.role %>
                </p>

            </div>

        </div>

    </div>

    <!-- ARTICLES SECTION -->

    <div>

        <h2 class="article-heading">

            <i class="fa-solid fa-newspaper"></i>

            My Articles

        </h2>

        <div class="row g-4">

            <% articles.forEach(article => { %>

                <div class="col-lg-4 col-md-6">

                    <div class="card article-card h-100">

                        <% if(article.image){ %>

                            <img
                                src="<%= article.image %>"
                                alt=""
                            >

                        <% } %>

                        <div class="card-body">

                            <span class="
                            
                                status-badge

                                <% if(article.status === 'approved'){ %>
                                    approved
                                <% } else if(article.status === 'pending'){ %>
                                    pending
                                <% } else { %>
                                    rejected
                                <% } %>

                            ">

                                <%= article.status %>

                            </span>

                            <h5 class="mt-3">
                                <%= article.title %>
                            </h5>

                            <p class="text-muted">
                                <%= article.city %>
                            </p>

                            <a
                                href="/articles/<%= article.id %>"
                                class="btn btn-primary"
                            >
                                Read More
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>