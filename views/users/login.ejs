<% layout("/layouts/boilerplate") -%>
    <div class="container d-flex justify-content-center" style="margin-top: 3rem; margin-bottom: 3rem;">
        <div class="form-container col-lg-6 col-md-8 col-12 p-4"
            style="background-color: white;border: 2px solid #2b06ff;border-radius: 10px;">
            <h2 class="mb-4 text-center" style="color: #2b06ff;">LOGIN</h2>
            <% if(error && error.length> 0){ %>
                <div class="alert alert-danger">
                    <%= error %>
                </div>
                <% } %>
                    <form class="row g-3 needs-validation" action="/users/login" method="POST" novalidate>
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon1">@</span>
                            <input type="text" class="form-control" placeholder="Username" aria-label="Username"
                                aria-describedby="basic-addon1" name="username" required>
                        </div>
                        <div>
                            <label for="inputPassword4" class="form-label">Password</label>
                            <input type="password" class="form-control" id="inputPassword4" name="password" required>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100">Log In
                            </button>
                        </div>
                    </form>
                    <div class="text-center mt-3">
                        Don't have an account?
                        <a href="/users/signup">
                            Signup
                        </a>
                    </div>
        </div>
    </div>
    <script src="/js/script.js"></script>