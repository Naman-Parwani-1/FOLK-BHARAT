<% layout("/layouts/boilerplate") -%>

<div class="container-fluid py-3">

    <h2 class="mb-4 fw-bold">
        <%= stateName %>
    </h2>

    <div class="row g-4 row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3">

        <% for(let article of articles){ %>

            <div class="col d-flex justify-content-center">

                <a href="/articles/<%=article.id%>"
                    style="text-decoration: none !important; width: 100%; max-width: 22rem;">

                    <div class="card h-100">

                        <img src="<%= article.image %>"
                            class="card-img-top"
                            alt="Article Image">

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">
                                <%=article.title%>
                            </h5>

                            <h6 class="card-subtitle mb-3 text-body-secondary">
                                <%=article.author%>
                            </h6>

                            <div class="mt-auto">

                                <form method="GET"
                                    action="/articles/<%=article.id%>">

                                    <button type="submit"
                                        class="btn btn-warning text-white w-100">

                                        Learn More

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </a>

            </div>

            <% } %>

    </div>

</div>