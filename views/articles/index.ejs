<% layout("/layouts/boilerplate") -%>

    <body>
        <div id="carouselExampleSlidesOnly" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner" style="border-radius: 10px;">
                <div class="carousel-item active">
                    <video width="600" autoplay muted loop class="d-block w-100" alt="" style="height: 400px;">
                        <source src="/assets/hero.mp4" type="video/mp4" >
                        Your browser does not support the video tag.
                    </video>
                </div>
                <div class="carousel-item">
                    <img src="/assets/Hero.jpeg" class="d-block w-100" alt="..." style="height: 400px;">
                </div>
                <div class="carousel-item">
                    <img src="/assets/Hero.jpeg" class="d-block w-100" alt="..." style="height: 400px;">
                </div>
            </div>
        </div>




        <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 cards-home">
            <a href="/articles/category/1" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/FolkMusic.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Folk Music</h2>
                    </div>
                </div>
            </a>

            <a href="/articles/category/2" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/FolkDance.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Folk Dance</h2>
                    </div>
                </div>
            </a>

            <a href="/articles/category/3" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/FolkArts.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Folk Arts</h2>
                    </div>
                </div>
            </a>

            <a href="/articles/category/4" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/Traditions.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Traditions</h2>
                    </div>
                </div>
            </a>

            <a href="/articles/category/5" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/CulturalPlaces.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Cultural Places</h2>
                    </div>
                </div>
            </a>

            <a href="/articles/category/6" style="text-decoration: none !important;">
                <div class="card col" style="width: 25rem; height: 10rem;">
                    <img src="/assets/Food.jpeg">
                    <div class="card-img-overlay">
                        <h2 class="card-title">Food</h2>
                    </div>
                </div>
            </a>
        </div>


        <h2 class="article-heading" style="margin-top: 26rem;">

            <i class="fa-solid fa-newspaper"></i>

            Latest Articles

        </h2>

        <div class="slider">
            <div class="slide-track">
                <% for(let article of articles){ %>
                    <a href="/articles/<%=article.id%>" style="text-decoration: none !important;">
                        <div class="card" style="width: 18rem;">
                            <img src="<%= article.image %>" class="card-img-top" alt="..." style="height: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%=article.title%>
                                </h5>
                                <h6 class="card-subtitle mb-2 text-body-secondary">
                                    <%=article.author%>
                                </h6>
                                <form method="GET" action="/articles/<%=article.id%>">
                                    <button type="submit" class="btn btn-warning" style="color: white;">Learn
                                        More</button>
                                </form>
                            </div>
                        </div>
                    </a>
                    <%}%>
                <% for(let article of articles){ %>
                    <a href="/articles/<%=article.id%>" style="text-decoration: none !important;">
                        <div class="card" style="width: 18rem;">
                            <img src="<%= article.image %>" class="card-img-top" alt="..." style="height: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%=article.title%>
                                </h5>
                                <h6 class="card-subtitle mb-2 text-body-secondary">
                                    <%=article.author%>
                                </h6>
                                <form method="GET" action="/articles/<%=article.id%>">
                                    <button type="submit" class="btn btn-warning" style="color: white;">Learn
                                        More</button>
                                </form>
                            </div>
                        </div>
                    </a>
                    <%}%>
            </div>
        </div>




    </body>