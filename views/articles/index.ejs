<% layout("/layouts/boilerplate") -%>

<div class="hero-carousel">

    <div id="carouselExampleSlidesOnly"
        class="carousel slide"
        data-bs-ride="carousel">

        <div class="carousel-inner">

            <div class="carousel-item active">

                <video autoplay muted loop class="d-block w-100">

                    <source src="/assets/hero.mp4" type="video/mp4">

                    Your browser does not support the video tag.

                </video>

            </div>

            <div class="carousel-item">

                <img src="/assets/Hero.jpeg"
                    class="d-block w-100"
                    alt="Hero Image">

            </div>

            <div class="carousel-item">

                <img src="/assets/Hero.jpeg"
                    class="d-block w-100"
                    alt="Hero Image">

            </div>

        </div>

    </div>

</div>

<div class="cards-home">

    <a href="/articles/category/1"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/FolkMusic.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Folk Music</h2>
            </div>

        </div>

    </a>

    <a href="/articles/category/2"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/FolkDance.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Folk Dance</h2>
            </div>

        </div>

    </a>

    <a href="/articles/category/3"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/FolkArts.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Folk Arts</h2>
            </div>

        </div>

    </a>

    <a href="/articles/category/4"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/Traditions.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Traditions</h2>
            </div>

        </div>

    </a>

    <a href="/articles/category/5"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/CulturalPlaces.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Cultural Places</h2>
            </div>

        </div>

    </a>

    <a href="/articles/category/6"
        style="text-decoration: none !important;">

        <div class="card">

            <img src="/assets/Food.jpeg">

            <div class="card-img-overlay">
                <h2 class="card-title">Food</h2>
            </div>

        </div>

    </a>

</div>

<h2 class="article-heading">

    <i class="fa-solid fa-newspaper"></i>

    Latest Articles

</h2>

<div class="slider">

    <div class="slide-track">

        <% for(let article of articles){ %>

            <a href="/articles/<%=article.id%>"
                style="text-decoration: none !important;">

                <div class="card" style="width: 18rem;">

                    <img src="<%= article.image %>"
                        class="card-img-top"
                        alt="Article Image">

                    <div class="card-body">

                        <h5 class="card-title">
                            <%=article.title%>
                        </h5>

                        <h6 class="card-subtitle mb-2 text-body-secondary">
                            <%=article.author%>
                        </h6>

                        <form method="GET"
                            action="/articles/<%=article.id%>">

                            <button type="submit"
                                class="btn btn-warning text-white">

                                Learn More

                            </button>

                        </form>

                    </div>

                </div>

            </a>

            <%}%>

                <% for(let article of articles){ %>

                    <a href="/articles/<%=article.id%>"
                        style="text-decoration: none !important;">

                        <div class="card" style="width: 18rem;">

                            <img src="<%= article.image %>"
                                class="card-img-top"
                                alt="Article Image">

                            <div class="card-body">

                                <h5 class="card-title">
                                    <%=article.title%>
                                </h5>

                                <h6 class="card-subtitle mb-2 text-body-secondary">
                                    <%=article.author%>
                                </h6>

                                <form method="GET"
                                    action="/articles/<%=article.id%>">

                                    <button type="submit"
                                        class="btn btn-warning text-white">

                                        Learn More

                                    </button>

                                </form>

                            </div>

                        </div>

                    </a>

                    <%}%>

    </div>

</div>