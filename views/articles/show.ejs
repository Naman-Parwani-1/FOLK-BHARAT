<% layout("/layouts/boilerplate") -%>

<div class="container-fluid py-3">

    <div class="card shadow-lg">

        <div class="card-header bg-white p-4">

            <div class="d-flex flex-column gap-3">

                <h2 class="fw-bold mb-0">

                    <%=article.title%>

                </h2>

                <div class="d-flex flex-wrap gap-2">

                    <span class="badge text-bg-warning text-white p-2">

                        <%=article.city%>

                    </span>

                    <span class="badge text-bg-warning text-white p-2">

                        <%=article.state_name%>

                    </span>

                    <span class="badge text-bg-warning text-white p-2">

                        <%=article.category_name%>

                    </span>

                </div>

            </div>

        </div>

        <div class="card-body p-4">

            <figure class="mb-0">

                <blockquote class="blockquote">

                    <p style="line-height: 1.9; font-size: 1.05rem;">

                        <%= article.content %>

                    </p>

                </blockquote>

                <figcaption class="blockquote-footer mt-4">

                    <%= article.author %>

                </figcaption>

            </figure>

        </div>

        <div class="card-footer bg-white p-4">

            <div class="d-flex flex-wrap gap-3">

                <form method="GET"
                    action="/articles/<%=article.id%>/edit">

                    <button class="btn btn-warning text-white px-4">

                        Edit

                    </button>

                </form>

                <form method="POST"
                    action="/articles/<%=article.id%>?_method=DELETE">

                    <button class="btn btn-danger px-4">

                        Delete

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>