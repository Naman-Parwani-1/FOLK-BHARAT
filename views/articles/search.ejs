<% layout("/layouts/boilerplate") -%>

    <body>
        <% if(articles.length> 0){ %>
            <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 row-cols-1">
                <% for(let article of articles){ %>
                    <a href="/articles/<%=article.id%>" style="text-decoration: none !important;">
                        <div class="card col" style="width: 18rem;">
                            <img src="<%= article.image %>" class="card-img-top" alt="..." style="height:18rem;">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%=article.title%>
                                </h5>
                                <h6 class="card-subtitle mb-2 text-body-secondary">
                                    <%=article.author%>
                                </h6>
                                <form method="GET" action="/articles/<%=article.id%>">
                                    <button type="submit" class="btn btn-warning" style="color: white;">Learn
                                        More</button>
                                </form>
                            </div>
                        </div>
                    </a>
                    <% } %>
            </div>
            <% } else if(search){ %>
                <h2>No Results Found</h2>
                <br><br>
                <br><br>
                <br><br>
                <% } %>
    </body>