<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FolkBharat Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background-color: #f4f6fb;
        }

        .dashboard-container {
            width: 95%;
            max-width: 1400px;
            margin: auto;
            padding: 2rem 0;
        }

        .top-header {
            background: white;
            border-radius: 20px;
            padding: 1.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            flex-wrap: wrap;
            gap: 1rem;
        }

        .top-header h1 {
            font-size: 2rem;
            color: #1f2a40;
            margin: 0;
        }

        .admin-box {
            background: #2b06ff;
            color: white;
            padding: 0.8rem 1.4rem;
            border-radius: 12px;
            font-weight: bold;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: white;
            padding: 1.8rem;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            transition: 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 2rem;
            color: #2b06ff;
            margin-bottom: 1rem;
        }

        .stat-card h2 {
            font-size: 2rem;
            color: #1f2a40;
            margin-bottom: 0.5rem;
        }

        .stat-card p {
            color: #666;
            margin: 0;
        }

        .section-box {
            background: white;
            border-radius: 20px;
            padding: 1.8rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            margin-bottom: 2rem;
        }

        .section-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .section-title h3 {
            color: #1f2a40;
            margin: 0;
        }

        .badge-pending {
            background-color: orange;
        }

        .table td,
        .table th {
            vertical-align: middle;
        }

        .action-btn {
            border: none;
            padding: 0.45rem 0.9rem;
            border-radius: 8px;
            color: white;
            font-size: 0.9rem;
            margin: 0.2rem;
        }

        .approve-btn {
            background-color: green;
        }

        .reject-btn {
            background-color: red;
        }

        .view-btn {
            background-color: #2b06ff;
        }

        .role-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .role-card {
            background: white;
            border-radius: 20px;
            padding: 1.8rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            text-align: center;
        }

        .role-card i {
            font-size: 2.5rem;
            color: #2b06ff;
            margin-bottom: 1rem;
        }

        .role-card h4 {
            margin-bottom: 1rem;
            color: #1f2a40;
        }

        .role-card p {
            color: #666;
            margin: 0;
        }

        @media(max-width: 768px) {
            .top-header {
                padding: 1.2rem;
            }

            .top-header h1 {
                font-size: 1.6rem;
            }

            .section-box {
                padding: 1rem;
            }

            .table {
                font-size: 0.9rem;
            }
        }
    </style>
</head>

<body>

    <div class="dashboard-container">

        <div class="top-header">
            <h1>FolkBharat Admin Dashboard</h1>

            <div class="admin-box">
                Welcome Admin
            </div>
        </div>

        <div class="stats-grid">

            <div class="stat-card">
                <i class="fa-solid fa-newspaper"></i>
                <h2>
                    <%= totalArticles %>
                </h2>
                <p>Total Articles</p>
            </div>

            <div class="stat-card">
                <i class="fa-solid fa-clock"></i>
                <h2>
                    <%= pendingArticlesCount %>
                </h2>
                <p>Pending Articles</p>
            </div>

            <div class="stat-card">
                <i class="fa-solid fa-file-circle-xmark"></i>
                <h2>
                    <%= rejectedArticlesCount %>
                </h2>
                <p>Rejected Articles</p>
            </div>

            <div class="stat-card">
                <i class="fa-solid fa-users"></i>
                <h2>
                    <%= totalUsersCount %>
                </h2>
                <p>Total Users</p>
            </div>

        </div>

        <div class="role-grid">

            <div class="role-card">
                <i class="fa-solid fa-user-shield"></i>
                <h4>Admin Access</h4>
                <p>
                    Full website control, user management,
                    article verification and analytics.
                </p>
                <h2>
                    <%= totalAdminsCount %>
                </h2>
            </div>

            <div class="role-card">
                <i class="fa-solid fa-user-pen"></i>
                <h4>Author Access</h4>
                <p>
                    Can directly publish, edit and manage
                    own articles.
                </p>
                <h2>
                    <%= totalAuthorsCount %>
                </h2>
            </div>

            <div class="role-card">
                <i class="fa-solid fa-user"></i>
                <h4>User Access</h4>
                <p>
                    Can submit articles for admin review
                    and explore the website.
                </p>
                <h2>
                    <%= totalUserAccessCount %>
                </h2>
            </div>

        </div>

        <div class="section-box">

            <div class="section-title">
                <h3>Pending Articles For Verification</h3>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>User</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% pendingArticles.forEach(article=> { %>

                            <tr>

                                <td>
                                    <%= article.title %>
                                </td>

                                <td>
                                    <%= article.username %>
                                </td>

                                <td>
                                    <span class="badge badge-pending">
                                        Pending
                                    </span>
                                </td>

                                <td>

                                    <a href="/articles/<%= article.id %>">
                                        <button class="action-btn view-btn">
                                            View
                                        </button>
                                    </a>

                                    <form action="/admin/articles/<%= article.id %>/approve?_method=PUT" method="POST"
                                        style="display:inline;">
                                        <button class="action-btn approve-btn">
                                            Approve
                                        </button>
                                    </form>

                                    <form action="/admin/articles/<%= article.id %>/reject?_method=PUT" method="POST"
                                        style="display:inline;">
                                        <button class="action-btn reject-btn">
                                            Reject
                                        </button>
                                    </form>

                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>
            </div>

        </div>

        <div class="section-box">

            <div class="section-title">
                <h3>User Management</h3>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% users.forEach(user=> { %>

                            <tr>

                                <td>
                                    <%= user.username %>
                                </td>

                                <td>
                                    <%= user.email %>
                                </td>

                                <td>
                                    <span class="badge bg-primary">
                                        <%= user.role %>
                                    </span>
                                </td>

                                <td>

                                    <form action="/admin/users/<%= user.u_id %>/role" method="POST">

                                        <select name="role" class="form-select">

                                            <option value="user">User</option>

                                            <option value="author">Author</option>

                                            <option value="admin">Admin</option>

                                        </select>

                                        <button class="btn btn-success btn-sm mt-2">
                                            Update
                                        </button>

                                    </form>

                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>
            </div>

        </div>

    </div>

</body>

</html>